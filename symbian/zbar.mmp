USERINCLUDE	. ../include/
USERINCLUDE	../zbar/

SYSTEMINCLUDE	 /epoc32/include
SYSTEMINCLUDE	 /epoc32/include/stdapis


OPTION GCCE -std=c99
OPTION CW -lang c99 -enc UTF-8

