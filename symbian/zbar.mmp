TARGET		libzbar.lib
TARGETTYPE	lib

SOURCEPATH      ../zbar 
SOURCE		img_scanner.c 
SOURCE		decoder.c 
SOURCE		image.c
SOURCE		symbol.c
SOURCE		convert.c
SOURCE		config.c
SOURCE		scanner.c
SOURCE		error.c
SOURCE		refcnt.c
SOURCE		video.c
SOURCE		video/null.c
SOURCE		decoder/code128.c
SOURCE		decoder/code39.c
SOURCE		decoder/code93.c
SOURCE		decoder/codabar.c
SOURCE		decoder/databar.c
SOURCE		decoder/ean.c
SOURCE		decoder/i25.c
SOURCE		decoder/qr_finder.c
